// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  username  String   @unique
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  submissions Submission[]
  progress    UserProblemProgress[]
}

model Problem {
  id          String     @id @default(uuid())
  title       String
  slug        String     @unique
  difficulty  Difficulty
  description String
  constraints String?
  solution    String?

  externalId String?
  frontendId String?

  timeLimitMs   Int @default(1000)
  memoryLimitKb Int @default(262144)

  isPublished Boolean @default(true)
  isPremium   Boolean @default(false)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  testCases             TestCase[]
  snippets              CodeSnippet[]
  tags                  ProblemTag[]
  submissions           Submission[]
  userProblemProgresses UserProblemProgress[]
  examples              Example[]
  hints                 Hint[]
  followUps             FollowUp[]

  @@index([difficulty])
  @@index([isPublished])
  @@index([categoryId])
  @@index([updatedAt(sort: Desc)])
  @@index([title, updatedAt(sort: Desc)], type: BTree)
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  problems Problem[]
}

model Tag {
  id       String       @id @default(uuid())
  name     String       @unique
  problems ProblemTag[]
}

model ProblemTag {
  problemId String
  tagId     String

  problem Problem @relation(fields: [problemId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([problemId, tagId])
}

model TestCase {
  id        String  @id @default(uuid())
  problemId String
  input     String
  expected  String
  isHidden  Boolean @default(true)
  order     Int

  problem           Problem            @relation(fields: [problemId], references: [id])
  submissionResults SubmissionResult[]

  @@unique([problemId, order])
  @@index([problemId])
}

model CodeSnippet {
  id        String   @id @default(uuid())
  problemId String
  language  Language
  template  String

  problem Problem @relation(fields: [problemId], references: [id])

  @@unique([problemId, language])
}

model Submission {
  id         String           @id @default(uuid())
  userId     String
  problemId  String
  language   Language
  sourceCode String
  status     SubmissionStatus @default(PENDING)

  runtimeMs Int?
  memoryKb  Int?

  startedAt  DateTime?
  finishedAt DateTime?
  judgeToken String?   @unique

  createdAt DateTime @default(now())

  user    User               @relation(fields: [userId], references: [id])
  problem Problem            @relation(fields: [problemId], references: [id])
  results SubmissionResult[]

  @@index([userId])
  @@index([problemId])
  @@index([userId, problemId])
  @@index([createdAt])
}

model SubmissionResult {
  id           String @id @default(uuid())
  submissionId String
  testCaseId   String

  passed    Boolean
  runtimeMs Int?
  memoryKb  Int?
  output    String?
  error     String?

  submission Submission @relation(fields: [submissionId], references: [id])
  testCase   TestCase   @relation(fields: [testCaseId], references: [id])

  @@unique([submissionId, testCaseId])
  @@index([submissionId])
}

model UserProblemProgress {
  userId        String
  problemId     String
  status        ProgressStatus
  bestRuntimeMs Int?
  bestMemoryKb  Int?
  solvedAt      DateTime?

  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@id([userId, problemId])
}

model Example {
  id        String @id @default(uuid())
  problemId String
  order     Int
  content   String

  problem Problem @relation(fields: [problemId], references: [id])

  @@unique([problemId, order])
  @@index([problemId])
}

model Hint {
  id        String @id @default(uuid())
  problemId String
  order     Int
  content   String

  problem Problem @relation(fields: [problemId], references: [id])

  @@unique([problemId, order])
  @@index([problemId])
}

model FollowUp {
  id        String @id @default(uuid())
  problemId String
  content   String

  problem Problem @relation(fields: [problemId], references: [id])

  @@index([problemId])
}

enum Role {
  USER
  ADMIN
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Language {
  CPP
  JAVA
  PYTHON
  PYTHON3
  JAVASCRIPT
  TYPESCRIPT
  GO
  RUST
  C
  CSHARP

  MYSQL
  MSSQL
  ORACLESQL
  POSTGRESQL
  PYTHONDATA
}

enum SubmissionStatus {
  PENDING
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILE_ERROR
}

enum ProgressStatus {
  ATTEMPTED
  SOLVED
}
